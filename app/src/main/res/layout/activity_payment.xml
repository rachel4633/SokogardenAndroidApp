<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7FAFA"
    tools:context=".PaymentActivity">


<!--    Below is a text view -->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Complete payment with M-Pesa"
        android:textSize="32sp"
        android:textAlignment="center"
        android:layout_marginTop="10dp"
        android:textStyle="bold"
        android:textColor="#0E8312"/>

<!--    Below is a cardview that holds all the contents-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:cardElevation="12dp"
        app:cardCornerRadius="20dp"
        android:background="#172657">

<!--        Below is a linearlayout -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#00001b">

<!--Below is a textview where the name of the product shall be binded/attached-->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductName"
                android:text="Product_Name"
                android:textSize="20sp"
                android:textStyle="bold|italic"
                android:textColor="#fff"/>

<!--            Below is imageview for the product image-->

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:id="@+id/imgProduct"
                android:src="@mipmap/ic_launcher"
                android:scaleType="fitXY"
                android:layout_marginTop="10dp"
                android:layout_marginRight="20dp"
                android:layout_marginLeft="20dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/txtProductCost"
                    android:text="Kes 100,000"
                    android:textSize="30sp"
                    android:textAlignment="center"
                    android:layout_marginTop="5dp"
                    android:textStyle="bold"
                    android:textColor="#fff"/>

<!--            below is a textview of description-->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtdescription"
                android:layout_marginTop="9sp"
                android:textAlignment="center"
                android:text="This is the Description"
                android:textColor="#fff"
                android:textSize="20sp"/>


<!--            Below is an edit text for entering mobile number-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/phone"
                android:hint="Enter Phone Number e.g 2547.."
                android:textColorHint="#fff"
                android:textColor="#fff"
                android:padding="15dp"
                android:layout_marginTop="10dp"
                android:background="#000059"/>

<!--            below is a button to complete the payment action-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/pay"
                android:text="Pay Now"
                android:layout_marginTop="25dp"
                android:layout_marginLeft="70dp"
                android:layout_marginRight="70dp"
                android:backgroundTint="#000086"
                android:textSize="20sp"
                android:textColor="#fff"/>



        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>