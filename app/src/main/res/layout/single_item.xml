<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00001b"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">
<!--    Below is a cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        app:cardBackgroundColor="#00003e"
        android:layout_margin="10dp"
        app:cardElevation="15dp"
        app:cardCornerRadius="15dp">

    </androidx.cardview.widget.CardView>
<!--    Below is another linearlayout that dictates how the contents will be aligned-->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#0A4D4D">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/product_name"
            android:text="Product_Name"
            android:textSize="23sp"
            android:textStyle="bold"
            android:background="#000032"
            android:textAlignment="center"
            android:textColor="#fff"
            android:fontFamily="sans-serif"/>
    </LinearLayout>

<!--    Below is product image-->

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:id="@+id/product_photo"
        android:src="@mipmap/ic_launcher"
        android:scaleType="centerCrop"
        android:layout_marginTop="3dp"/>

<!--    Below is a textview for the product_cost-->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/product_cost"
        android:text="Kes 500"
        android:textAlignment="center"
        android:layout_marginTop="5dp"
        android:textStyle="bold"
        android:textSize="18dp"
        android:background="#000032"
        android:textColor="#fff"
        android:layout_marginLeft="10dp"/>

<!--    Below is the Textview for the product_description-->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/product_description"
        android:text="The product description will appear here ...."
        android:textColor="#fff"
        android:padding="4dp"
        android:textAlignment="center"
        android:layout_marginLeft="10dp"
        android:textStyle="italic|bold"
        android:background="#000032"
        android:layout_marginTop="3dp"/>

<!--    Below is the purchase button-->
    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnPurchase"
        android:text="Purchase Now"
        android:layout_marginTop="3dp"
        android:layout_marginLeft="70dp"
        android:layout_marginRight="70dp"
        android:backgroundTint="#960000"
        android:paddingBottom="2dp"
        android:textSize="13sp"
        android:textColor="#eae6e6"/>
    </LinearLayout>