<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:background="@drawable/signup_background"
    tools:context=".Signup">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✨Signup✨"
        android:textSize="38sp"
        android:fontFamily="cursive"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:textColor="#D5DDE6"
        android:background="@drawable/shape" />


    <ImageView
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@drawable/icon_signup_circle"/>



<!--    below is a cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:cardElevation="10dp"
        android:layout_margin="12dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

<!--            Below is the edittext for username -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="👤Enter Your Username"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/username"
                android:layout_margin="8dp"
                android:background="#FC307A"
                android:padding="10dp"/>

            <!--     Below is the edittext for email -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧Enter Your Email"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/email"
                android:layout_margin="8dp"
                android:inputType="textEmailAddress"
                android:background="#FC307A"
                android:padding="10dp"/>

            <!--    Below is the edittext for password -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint=" 🔑Enter Your password"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/password"
                android:inputType="textPassword"
                android:layout_margin="8dp"
                android:background="#FC307A"
                android:padding="10dp"/>

            <!--      Below is the edittext for phone number -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📞Enter Your phone number"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/phone"
                android:inputType="number"
                android:layout_margin="8dp"
                android:background="#FC307A"
                android:padding="10dp"/>

<!--            below is the signup button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤Signup"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:layout_marginTop="25dp"
                android:textColor="#F1F4F8"
                android:backgroundTint="#053F75"
                android:id="@+id/signupbtn"/>

          <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Already Have an Account? Signin"
                android:textAlignment="center"
                android:textSize="23sp"
                android:layout_marginTop="25dp"
                android:textColor="#4F31FC"
                android:id="@+id/signintxt"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>



</LinearLayout>